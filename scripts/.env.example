# ============================================================
# SANAD Backend — Environment Configuration Template
# ============================================================
# Copy this file to /srv/sanad/config/.env and fill in real values.
# NEVER commit the .env file to Git.
# Set file permissions: chmod 600 /srv/sanad/config/.env
# ============================================================

# ─── Database (Supabase PostgreSQL) ───
DATABASE_URL=jdbc:postgresql://aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_USERNAME=sanad_app.hxhvfqxzigrqoxxnnzje
DATABASE_PASSWORD=CHANGE_ME_TO_YOUR_SUPABASE_DB_PASSWORD
DATABASE_DRIVER=org.postgresql.Driver

# ─── JWT (generate a FIXED secret, do NOT change after deployment) ───
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Or: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_FIXED_64_CHAR_RANDOM_STRING

# ─── Application ───
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
LAZY_INIT=false
SHUTDOWN_TIMEOUT=30s

# ─── Control Plane ───
SANAD_CONTROL_PLANE_TENANT_ID=958bbb1c-eece-4839-bca8-a5bfa14e6ac1
CONTROL_PLANE_BOOTSTRAP_ENABLED=false
BOOTSTRAP_ENABLED=false

# ─── CORS (your Vercel frontend URL) ───
SANAD_CORS_ALLOWED_ORIGINS=https://snad-app.vercel.app
APPLICATION_BASE_URL=https://snad-app.vercel.app

# ─── Connection Pool ───
DATABASE_POOL_MAX=5
DATABASE_POOL_MIN=1
DATABASE_POOL_TIMEOUT=30000

# ─── Logging ───
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SANAD=INFO
MANAGEMENT_ENDPOINTS=health

# ─── Email/Notifications (optional, for password reset) ───
SECURITY_NOTIFICATION_PROVIDER=resend
SECURITY_NOTIFICATION_RESEND_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY
SECURITY_NOTIFICATION_FROM=SANAD <onboarding@resend.dev>
SECURITY_NOTIFICATION_ENDPOINT=https://snad-app.vercel.app/api/email-proxy

# ─── Paths (override defaults if needed) ───
# SANAD_LOG_FILE=/var/log/sanad/backend.log
# SANAD_PID_FILE=/var/run/sanad-backend.pid
# SANAD_ENV_FILE=/srv/sanad/config/.env
