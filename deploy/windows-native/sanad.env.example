# Copy to C:\SANAD\config\sanad.env and replace every placeholder.
# Never commit the real file or send its contents in chat.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://127.0.0.1:5432/sanad
DATABASE_USERNAME=sanad_app
DATABASE_PASSWORD=REPLACE_WITH_SANAD_APP_PASSWORD
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_POOL_MAX=3
DATABASE_POOL_MIN=1
DATABASE_POOL_TIMEOUT=30000
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_VALIDATE_ON_MIGRATE=true

JWT_SECRET=REPLACE_WITH_EXISTING_RENDER_JWT_SECRET
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
JWT_ISSUER=sanad-platform

SANAD_CORS_ALLOWED_ORIGINS=https://snad-app.vercel.app
APPLICATION_BASE_URL=https://snad-app.vercel.app
COOKIE_SECURE=true
COOKIE_SAME_SITE=None
COOKIE_DOMAIN=

BOOTSTRAP_ENABLED=false
BOOTSTRAP_FORCE_RESET=false
BOOTSTRAP_TENANT_ID=
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_SUBDOMAIN=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=SANAD Admin
BOOTSTRAP_AUDIT_ACTOR=credential-bootstrap
SANAD_CONTROL_PLANE_TENANT_ID=

SECURITY_NOTIFICATION_PROVIDER=resend
SECURITY_NOTIFICATION_FROM=
SECURITY_NOTIFICATION_RESEND_API_KEY=
SECURITY_NOTIFICATION_ENDPOINT=https://snad-app.vercel.app/api/email-proxy
SECURITY_NOTIFICATION_BEARER_TOKEN=

LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SANAD=INFO
LAZY_INIT=true
MANAGEMENT_ENDPOINTS=health
SHUTDOWN_TIMEOUT=30s

# Tuned for the 6 GB RAM / dual-core Windows host.
SANAD_JAVA_OPTS=-Xms128m -Xmx768m -XX:+UseSerialGC -XX:MaxMetaspaceSize=192m -XX:MaxDirectMemorySize=64m -Xss512k -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Dfile.encoding=UTF-8
