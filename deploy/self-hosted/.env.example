# Copy to .env using scripts/windows/install-snad-autostart.ps1.
# Never commit the generated .env file.

POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=replace-with-a-long-random-password

JWT_SECRET=replace-with-at-least-64-random-bytes
CRM_CUSTOM_FIELD_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# Cloudflare remotely-managed tunnel token. Keep secret.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Exact browser origins allowed to call the backend. Separate multiple origins with commas
# only if the backend's CORS parser supports the configured list.
SANAD_CORS_ALLOWED_ORIGINS=https://snad-app.vercel.app
APPLICATION_BASE_URL=https://snad-app.vercel.app

# Cross-site secure cookies are required when Vercel and the API use different sites.
COOKIE_SAME_SITE=none
COOKIE_DOMAIN=

BOOTSTRAP_ENABLED=false
SECURITY_NOTIFICATION_PROVIDER=disabled

# Override only when the local machine has different memory constraints.
JAVA_OPTS=-Xms256m -Xmx1024m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError -Dfile.encoding=UTF-8
