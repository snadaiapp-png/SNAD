# Copy to deploy/local/.env and never commit the real file.

# Cloudflare Tunnel token copied from the Cloudflare dashboard.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN

# Public application URLs
APPLICATION_BASE_URL=https://snad-app.vercel.app
SANAD_CORS_ALLOWED_ORIGINS=https://snad-app.vercel.app
COOKIE_SAME_SITE=None

# PostgreSQL
POSTGRES_DB=sanad
DATABASE_USERNAME=sanad_app
DATABASE_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_DATABASE_PASSWORD
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2
DATABASE_POOL_TIMEOUT=30000

# Authentication. Preserve the current Render JWT secret during migration.
JWT_SECRET=REPLACE_WITH_CURRENT_RENDER_JWT_SECRET

# Bootstrap must remain disabled after controlled initialization.
BOOTSTRAP_ENABLED=false
BOOTSTRAP_TENANT_ID=
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_SUBDOMAIN=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=SANAD Admin
SANAD_CONTROL_PLANE_TENANT_ID=

# Notifications
SECURITY_NOTIFICATION_PROVIDER=resend
SECURITY_NOTIFICATION_FROM=
SECURITY_NOTIFICATION_RESEND_API_KEY=
SECURITY_NOTIFICATION_ENDPOINT=https://snad-app.vercel.app/api/email-proxy
SECURITY_NOTIFICATION_BEARER_TOKEN=

# Local diagnostics. Bound to 127.0.0.1 only.
BACKEND_DEBUG_PORT=18080
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SANAD=INFO
JAVA_OPTS=-Xms256m -Xmx2048m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError -Dfile.encoding=UTF-8
GIT_COMMIT=local-cloudflare
