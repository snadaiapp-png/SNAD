# SNAD unified runtime environment template
# Run `make bootstrap` to create a local .env with generated development secrets.
# Never commit .env or copy production credentials into this file.

COMPOSE_PROJECT_NAME=snad

# Runtime mode
SPRING_PROFILES_ACTIVE=container,crm-platform
NODE_ENV=production

# Host ports
WEB_PORT=3000
BACKEND_PORT=8080
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
CRM_GATEWAY_PORT=8088
CRM_BROKER_MANAGEMENT_PORT=15672
CRM_STORAGE_API_PORT=9000
CRM_STORAGE_CONSOLE_PORT=9001

# PostgreSQL — local development values only
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/sanad
SPRING_DATASOURCE_USERNAME=sanad
SPRING_DATASOURCE_PASSWORD=
DATABASE_POOL_MAX=40
DATABASE_POOL_MIN=5
DATABASE_POOL_TIMEOUT=30000
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
QUARTZ_INITIALIZE_SCHEMA=never

# Application security — generated by scripts/dev/bootstrap.sh
JWT_SECRET=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BOOTSTRAP_ENABLED=false

# Local service URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8088
APPLICATION_BASE_URL=http://localhost:8088
SANAD_CORS_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088

# CRM event platform
CRM_MESSAGING_ENABLED=true
CRM_BROKER_USERNAME=snad
CRM_BROKER_PASSWORD=
CRM_BROKER_VHOST=/snad
CRM_OUTBOX_BATCH_SIZE=100
CRM_OUTBOX_MAX_ATTEMPTS=12
CRM_OUTBOX_POLL_INTERVAL=2s

# CRM cache and distributed coordination
CRM_CACHE_HOST=valkey
CRM_CACHE_PORT=6379
CRM_CACHE_PASSWORD=

# CRM workflow and scheduling
CRM_WORKFLOW_ENABLED=true
CRM_WORKFLOW_TIMER_BATCH_SIZE=100
CRM_WORKFLOW_POLL_INTERVAL=5s

# CRM search
CRM_SEARCH_ENABLED=true
CRM_SEARCH_URL=http://opensearch:9200
CRM_SEARCH_INDEX_PREFIX=snad-crm
CRM_SEARCH_TIMEOUT=10s

# CRM S3-compatible object storage
CRM_STORAGE_ENABLED=true
CRM_STORAGE_ENDPOINT=http://minio:9000
CRM_STORAGE_REGION=us-east-1
CRM_STORAGE_BUCKET=snad-crm
CRM_STORAGE_PATH_STYLE=true
CRM_STORAGE_ACCESS_KEY=
CRM_STORAGE_SECRET_KEY=
CRM_STORAGE_PRESIGN_DURATION=10m

# CRM attachment security
CRM_ANTIVIRUS_ENABLED=true
CRM_ANTIVIRUS_HOST=clamav
CRM_ANTIVIRUS_PORT=3310
CRM_ANTIVIRUS_TIMEOUT=30s

# CRM notifications
CRM_NOTIFICATIONS_ENABLED=true
CRM_NOTIFICATION_FROM=no-reply@snad.local
CRM_NOTIFICATION_BATCH_SIZE=100
SECURITY_NOTIFICATION_PROVIDER=disabled
SECURITY_NOTIFICATION_FROM=
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025

# Central AI gateway — disabled until an approved policy gateway is connected
CRM_AI_GATEWAY_ENABLED=false
CRM_AI_GATEWAY_URL=http://ai-gateway:8080
CRM_AI_GATEWAY_API_KEY=
CRM_AI_GATEWAY_TIMEOUT=20s

# Webhooks and integrations
CRM_WEBHOOKS_ENABLED=true
CRM_WEBHOOK_TIMEOUT=10s
CRM_WEBHOOK_MAX_ATTEMPTS=8

# Observability
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SANAD=INFO
MANAGEMENT_SERVER_PORT=8080
OTEL_TRACING_ENABLED=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_TRACES_SAMPLER_PROBABILITY=1.0

# Local image baselines
REDIS_IMAGE=redis:8-alpine
REDIS_PASSWORD=
MAILPIT_IMAGE=axllent/mailpit:v1.27
PROMETHEUS_IMAGE=prom/prometheus:v3
GRAFANA_IMAGE=grafana/grafana:12

# Production-only values are intentionally absent. Configure them only in the
# approved deployment secret manager and follow the runtime configuration matrix.
