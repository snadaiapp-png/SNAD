# SNAD unified runtime environment template
# Run `make bootstrap` to create a local .env with generated development secrets.
# Never commit .env or copy production credentials into this file.

COMPOSE_PROJECT_NAME=snad

# Runtime mode
SPRING_PROFILES_ACTIVE=container
NODE_ENV=production

# Host ports
WEB_PORT=3000
BACKEND_PORT=8080
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# PostgreSQL — local development values only
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=sanad
POSTGRES_USER=sanad
POSTGRES_PASSWORD=
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/sanad
SPRING_DATASOURCE_USERNAME=sanad
SPRING_DATASOURCE_PASSWORD=
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true

# Application security — generated by scripts/dev/bootstrap.sh
JWT_SECRET=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
BOOTSTRAP_ENABLED=false

# Local service URLs
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
APPLICATION_BASE_URL=http://localhost:3000
SANAD_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:3000

# Logging and health
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SANAD=INFO
MANAGEMENT_SERVER_PORT=8080

# Local email capture. External delivery remains disabled.
SECURITY_NOTIFICATION_PROVIDER=disabled
SECURITY_NOTIFICATION_FROM=
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025

# Optional platform services
REDIS_IMAGE=redis:8-alpine
REDIS_PASSWORD=
MAILPIT_IMAGE=axllent/mailpit:v1.27
PROMETHEUS_IMAGE=prom/prometheus:v3
GRAFANA_IMAGE=grafana/grafana:12

# Production-only values are intentionally absent. Configure them only in the
# approved deployment secret manager and follow the runtime configuration matrix.
