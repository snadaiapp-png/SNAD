# ============================================================
# SANAD Platform — Environment Variable Template
# ------------------------------------------------------------
# Copy this file to .env and fill in real values for your
# environment. NEVER commit the .env file with real secrets.
#
# Usage with docker-compose.prod.yml:
#   cp .env.example .env
#   # edit .env with your values
#   docker compose -f apps/sanad-platform/docker-compose.prod.yml --env-file .env up -d --build
# ============================================================

# --- Server ---
SERVER_PORT=8080

# --- Spring Profile ---
# Use "prod" for production, "local" for development with H2
SPRING_PROFILES_ACTIVE=prod

# --- Database (PostgreSQL) ---
# NOTE: Docker Compose requires an explicit secure value for DATABASE_PASSWORD.
# No production password default is provided. Replace REPLACE_WITH_SECURE_PASSWORD
# with a strong password before starting the composition.
DATABASE_URL=jdbc:postgresql://localhost:5432/sanad
DATABASE_USERNAME=sanad
DATABASE_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DATABASE_DRIVER=org.postgresql.Driver

# --- Connection Pool ---
DATABASE_POOL_MAX=20
DATABASE_POOL_MIN=5
DATABASE_POOL_TIMEOUT=30000

# --- JPA / Hibernate ---
# Production MUST use "validate" — never "create" or "update"
JPA_DDL_AUTO=validate

# --- Flyway ---
FLYWAY_ENABLED=true

# --- CORS ---
# Comma-separated exact HTTPS origins. Wildcards are NOT allowed.
SANAD_CORS_ALLOWED_ORIGINS=https://snad-app.vercel.app

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SANAD=INFO

# --- Actuator ---
# Comma-separated list of endpoints to expose
MANAGEMENT_ENDPOINTS=health

# --- Shutdown ---
SHUTDOWN_TIMEOUT=30s
