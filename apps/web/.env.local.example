# Local Next.js server-side connection to the SANAD backend.
# Browser requests use the same-origin /api/platform BFF.
BACKEND_API_BASE_URL=http://127.0.0.1:8080
BACKEND_REQUEST_TIMEOUT_MS=15000

# Optional direct-browser development only. Leave unset to avoid CORS and
# refresh-cookie problems.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
