<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <suppress until="2026-10-01Z">
        <notes><![CDATA[Micrometer registry is not the Prometheus server product.]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.micrometer/micrometer-registry-prometheus@.*$</packageUrl>
        <cve>CVE-2026-42154</cve>
    </suppress>

    <suppress until="2026-10-01Z">
        <notes><![CDATA[Kotlin 1.9.25 is newer than the documented fixed release.]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-stdlib(-common|-jdk7|-jdk8)?@1\.9\.25$</packageUrl>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <suppress until="2026-10-01Z">
        <notes><![CDATA[The scanned Netty modules are outside the affected module line.]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/(netty-buffer|netty-codec|netty-common|netty-handler|netty-resolver|netty-transport(-classes-epoll|-native-unix-common)?)@4\.1\.135\.Final$</packageUrl>
        <cve>CVE-2026-42582</cve>
    </suppress>

    <suppress until="2026-10-01Z">
        <notes><![CDATA[Exact module identity correction.]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty-codec-http@4\.1\.135\.Final$</packageUrl>
        <cve>CVE-2026-42582</cve>
    </suppress>
</suppressions>
