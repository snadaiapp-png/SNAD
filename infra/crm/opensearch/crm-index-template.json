{
  "index_patterns": ["snad-crm-*"],
  "priority": 500,
  "template": {
    "settings": {
      "index.number_of_shards": 3,
      "index.number_of_replicas": 0,
      "index.refresh_interval": "5s",
      "index.max_result_window": 10000,
      "index.knn": true,
      "analysis": {
        "normalizer": {
          "crm_keyword_normalizer": {
            "type": "custom",
            "filter": ["lowercase", "asciifolding"]
          }
        },
        "analyzer": {
          "crm_arabic": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "decimal_digit",
              "arabic_normalization",
              "arabic_stemmer"
            ]
          },
          "crm_english": {
            "type": "custom",
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "asciifolding",
              "english_possessive_stemmer",
              "english_stemmer"
            ]
          }
        },
        "filter": {
          "arabic_stemmer": {
            "type": "stemmer",
            "language": "arabic"
          },
          "english_possessive_stemmer": {
            "type": "stemmer",
            "language": "possessive_english"
          },
          "english_stemmer": {
            "type": "stemmer",
            "language": "english"
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "_routing": {
        "required": true
      },
      "properties": {
        "tenant_id": {
          "type": "keyword"
        },
        "entity_type": {
          "type": "keyword"
        },
        "entity_id": {
          "type": "keyword"
        },
        "document_version": {
          "type": "long"
        },
        "lifecycle_status": {
          "type": "keyword"
        },
        "display_name": {
          "type": "text",
          "analyzer": "crm_arabic",
          "fields": {
            "en": {
              "type": "text",
              "analyzer": "crm_english"
            },
            "keyword": {
              "type": "keyword",
              "normalizer": "crm_keyword_normalizer",
              "ignore_above": 512
            }
          }
        },
        "email": {
          "type": "keyword",
          "normalizer": "crm_keyword_normalizer"
        },
        "phone_e164": {
          "type": "keyword"
        },
        "account_id": {
          "type": "keyword"
        },
        "owner_user_id": {
          "type": "keyword"
        },
        "pipeline_id": {
          "type": "keyword"
        },
        "stage_id": {
          "type": "keyword"
        },
        "tags": {
          "type": "keyword",
          "normalizer": "crm_keyword_normalizer"
        },
        "locale": {
          "type": "keyword"
        },
        "currency_code": {
          "type": "keyword"
        },
        "amount": {
          "type": "scaled_float",
          "scaling_factor": 100
        },
        "event_at": {
          "type": "date"
        },
        "created_at": {
          "type": "date"
        },
        "updated_at": {
          "type": "date"
        },
        "search_text": {
          "type": "text",
          "analyzer": "crm_arabic",
          "fields": {
            "en": {
              "type": "text",
              "analyzer": "crm_english"
            }
          }
        },
        "embedding": {
          "type": "knn_vector",
          "dimension": 1536,
          "method": {
            "name": "hnsw",
            "space_type": "cosinesimil",
            "engine": "lucene",
            "parameters": {
              "ef_construction": 128,
              "m": 16
            }
          }
        },
        "metadata": {
          "type": "flat_object"
        }
      }
    }
  },
  "_meta": {
    "owner": "SNAD CRM",
    "routing": "tenant_id",
    "source_of_truth": "PostgreSQL",
    "schema_version": 1
  }
}
